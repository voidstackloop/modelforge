{
  "name": "app",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "dev:renderer": "npm --prefix ../frontend run dev",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist/main.js && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -s first \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:all": "npm --prefix ../frontend run build && npm run build",
    "package": "npm run build:all && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.modelforge.app",
    "productName": "Modelforge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/tesseract.js/**",
      "**/node_modules/tesseract.js-core/**",
      "**/node_modules/node-llama-cpp/**",
      "**/node_modules/@node-llama-cpp/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend-dist"
      }
    ],
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "voidstackloop",
      "repo": "modelforge"
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "ffmpeg-static": "^5.3.0",
    "node-llama-cpp": "^3.19.1",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^5.1.1"
  }
}
